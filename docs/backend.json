
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "企业用户画像，存储个人偏好及收藏的策略。",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "starredStrategyIds": {
          "type": "array",
          "description": "用户收藏的策略 ID 列表。",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "用户上传的技术文档元数据及解析状态。",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_confirm", "processing", "completed", "error"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "chatHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "userId", "status", "createdAt"]
    },
    "ExtractionStrategy": {
      "title": "ExtractionStrategy",
      "type": "object",
      "description": "解析策略市场中的共享规则。",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "starCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "content", "authorId", "starCount"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "存储用户个人配置及收藏夹。"
    },
    "/users/{userId}/documents/{documentId}": {
      "schema": "Document",
      "description": "存储用户私有的文档及聊天历史，实现数据隔离。"
    },
    "/extractionStrategies/{strategyId}": {
      "schema": "ExtractionStrategy",
      "description": "全球策略市场，存储共享的解析逻辑及星标数。"
    }
  }
}
