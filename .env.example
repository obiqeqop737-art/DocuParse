# DocuParse 环境变量配置

# SiliconFlow API (用于 DeepSeek V3.2 对话)
SILICON_FLOW_API_KEY=your_siliconflow_api_key_here

# Google GenAI API (用于 OCR/ASR 图像识别)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Firebase 配置 (可选，如果使用 Firestore 存储策略)
# 通常 Vercel 会自动从 firebaseConfig 注入，以下保留以便本地开发
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-937136369-19c90
# NEXT_PUBLIC_FIREBASE_APP_ID=1:597923930898:web:6551ab868e5cf4f028c9cb
# NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
