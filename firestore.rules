rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DocuParse Pro Security Rules Documentation
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;

      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }

    match /extractionStrategies/{strategyId} {
      // 允许公共读取，无需登录即可看到广场内容（增强稳定性）
      allow get, list: if (resource.data.isPublic == true) || (isSignedIn() && resource.data.authorId == request.auth.uid);
      
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid && isUnchanged('authorId');
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
  }
}