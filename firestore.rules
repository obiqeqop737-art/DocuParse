rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DocuParse Pro Security Rules
     * 
     * Core Philosophy: 
     * This ruleset implements a strict user-ownership model. All application data 
     * is organized under a top-level `/users/{userId}` path, ensuring that users 
     * can only access and modify their own documents, extraction rules, and 
     * resource consumption logs.
     * 
     * Data Structure:
     * - Documents, Extraction Rules, and Traffic Logs are stored in user-specific subcollections.
     * - Extracted Data Items are nested further under specific documents to maintain 
     *   hierarchical integrity.
     * - Global roles (Admins) are managed via the `/roles_admin` collection using 
     *   an "existence-over-content" pattern.
     * 
     * Key Security Decisions:
     * - Authorization Independence: User IDs are included in both the path and the 
     *   document data. Rules validate that these match to prevent cross-user data injection.
     * - Relational Integrity: Critical fields like `userId` and `documentId` are 
     *   validated on creation and enforced as immutable during updates.
     * - Prototyping Flexibility: While authorization is strictly enforced based on 
     *   identity, the internal schema (field types, optionality) is not validated 
     *   to allow for rapid iteration of the data model.
     * - Admin Access: A global `isAdmin()` helper allows for administrative overrides 
     *   or backend processing needs if necessary.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is an owner and the document currently exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the user has administrative privileges via the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for technical documents uploaded by users.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create) User 'abc' creates a document at /users/abc/documents/doc123 with userId 'abc'.
     * @deny (list) User 'abc' attempts to list documents at /users/xyz/documents.
     * @principle Path-based ownership with relational integrity validation.
     */
    match /users/{userId}/documents/{documentId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for data items extracted from a specific document.
       * @path /users/{userId}/documents/{documentId}/extractedDataItems/{dataItemId}
       * @allow (get) User 'abc' reads an extracted item belonging to their document.
       * @deny (update) User 'abc' attempts to change the 'documentId' or 'userId' of an item.
       * @principle Subcollection ownership requiring denormalized userId for atomic checks.
       */
      match /extractedDataItems/{dataItemId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.documentId == documentId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.documentId == resource.data.documentId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for custom extraction rule sets defined by users.
     * @path /users/{userId}/extractionRuleSets/{ruleSetId}
     * @allow (update) User 'abc' modifies their own rule set.
     * @deny (create) User 'abc' tries to create a rule set in User 'xyz's path.
     * @principle Enforces that rule sets are private and owned by the creator.
     */
    match /users/{userId}/extractionRuleSets/{ruleSetId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for logging resource and traffic consumption.
     * @path /users/{userId}/trafficConsumptionLogs/{logId}
     * @allow (list) User 'abc' views their own consumption history for statistics.
     * @deny (delete) Users are generally prevented from deleting logs to maintain audit integrity.
     * @principle Secure attribution of traffic usage to the specific authenticated user.
     */
    match /users/{userId}/trafficConsumptionLogs/{logId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      // Updates and deletes are restricted to admins to ensure log integrity
      allow update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles collection. Presence of a document grants admin status.
     * @path /roles_admin/{userId}
     * @allow (get) Any signed-in user checks if they have admin status.
     * @deny (write) Users attempting to grant themselves admin privileges.
     * @principle Existence-over-content pattern for global RBAC.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Admin roles managed via Admin SDK/Console only.
    }
  }
}